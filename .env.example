# ==========================================
# Deployment Environment Variables
# ==========================================

# 1. Spring Active Profile
SPRING_PROFILES_ACTIVE=prod

# 2. Database Configuration (Railway MySQL)
SPRING_DATASOURCE_USERNAME=<DB_USER>
SPRING_DATASOURCE_PASSWORD=<DB_PASSWORD>

# 3. Security Configuration
# Generate a strong 256-bit base64 secret key
JWT_SECRET=dGhpcy1pcy1hLXZlcnktc2VjdXJlLWtleS13aGljaC1pcy1hdC1sZWFzdC0yNTYtYml0cy1sb25n
JWT_EXPIRATION=86400000

# 4. CORS Configuration (Vercel Frontend URL)
# Example: https://jobportal-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://job-portal-tan-three.vercel.app,http://localhost:5173

# 5. Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_API_SECRET>

# 6. SMTP Configuration (Gmail App Passwords or SendGrid)
SMTP_USERNAME=<YOUR_EMAIL>
SMTP_PASSWORD=<YOUR_APP_PASSWORD>

# 7. Google Gemini AI Configuration
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# ==========================================
# Frontend Build Environment Variables (Vercel)
# ==========================================
VITE_API_BASE_URL=https://job-portal-fx9f.onrender.com
